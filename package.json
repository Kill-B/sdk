{
  "name": "@killb/sdk",
  "version": "2.5.2",
  "description": "KillB sdk",
  "main": "lib/cjs/index.js",
  "types": "./lib/cjs/types/index.d.ts",
  "directories": {
    "lib": "src"
  },
  "scripts": {
    "clean": "rm -rf lib",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p ./tsconfig.esm.json && mv lib/esm/index.js lib/esm/index.mjs",
    "build:cjs": "tsc -p ./tsconfig.cjs.json",
    "prepack": "npm run build",
    "test": "jest --logHeapUsage --runInBand",
    "test:ci": "npm test -- --coverage --silent --noStackTrace",
    "test:dev": "npm test --watch",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kill-B/sdk.git"
  },
  "keywords": [
    "killb"
  ],
  "author": "Kill-B",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Kill-B/sdk/issues"
  },
  "homepage": "https://github.com/Kill-B/sdk#readme",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./lib/esm/types/index.d.ts",
        "default": "./lib/esm/index.mjs"
      },
      "require": {
        "types": "./lib/cjs/types/index.d.ts",
        "default": "./lib/cjs/index.js"
      }
    }
  },
  "files": [
    "lib/**/*"
  ],
  "release": {
    "branches": [
      "main"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.15.2"
  }
}
